    "@xenova/transformers": {
      "optional": true
    }
  },
  "dependencies": {
    "@medv/finder": "^3.2.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "parsel-js": "^1.2.2",
    "react-speech-recognition": "^4.0.1",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@central-icons-react/round-outlined-radius-2-stroke-1.5": "^1.1.153",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
