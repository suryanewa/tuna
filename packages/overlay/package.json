{
  "name": "retune",
  "version": "0.7.6",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/khadgi-sujan/retune"
  },
  "homepage": "https://retune.dev",
  "license": "PolyForm-Shield-1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "retune": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skill"
