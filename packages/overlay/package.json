{
  "name": "@suryanewa/tuna",
  "version": "0.7.6",
  "description": "Visual DevTools overlay for selecting, tuning, annotating, and handing off UI changes to AI coding agents.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khadgi-sujan/tuna.git"
  },
  "homepage": "https://tuna.dev",
  "license": "PolyForm-Shield-1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "tuna": "dist/cli.js"
  },
  "files": [
    "dist",
    "skill"
  ],
  "scripts": {
    "build:css": "node scripts/build-css.js",
    "watch:css": "node scripts/build-css.js --watch",
    "build": "npm run build:css && rm -rf dist && tsup",
    "dev": "node scripts/dev.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && vitest run"
  },
  "peerDependencies": {
    "@xenova/transformers": ">=2.17.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    }
  },
  "dependencies": {
    "@lexical/react": "^0.45.0",
    "@medv/finder": "^3.2.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "lexical": "^0.45.0",
    "parsel-js": "^1.2.2",
    "react-speech-recognition": "^4.0.1",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
