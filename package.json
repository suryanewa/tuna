{
  "name": "retune",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "clean": "rm -rf packages/*/dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "retune": "^0.3.0"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
