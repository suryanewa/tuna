{
  "name": "tuna-monorepo",
  "private": true,
  "description": "Monorepo for the Tuna visual editing overlay, playground, and Chrome extension.",
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:overlay": "npm run build -w tuna",
    "build:extension": "npm run build -w @tuna/chrome-extension",
    "build:playground": "npm run build -w playground",
    "dev": "concurrently -k -n overlay,playground -c blue,green \"npm run dev -w tuna\" \"npm run dev -w playground\"",
    "dev:overlay": "npm run dev -w tuna",
    "dev:playground": "npm run dev -w playground",
    "clean": "rm -rf packages/*/dist",
    "test": "vitest run",
    "test:extension": "npm run test -w @tuna/chrome-extension",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "vitest": "^4.0.18"
  }
}
