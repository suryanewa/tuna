{
  "name": "tuna",
  "private": true,
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently -k -n overlay,playground -c blue,green \"npm run dev -w tuna\" \"npm run dev -w playground\"",
    "dev:overlay": "npm run dev -w tuna",
    "dev:playground": "npm run dev -w playground",
    "clean": "rm -rf packages/*/dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "tuna": "^0.3.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "vitest": "^4.0.18"
  }
}
